# --- 前処理を関数化 ---
def preprocess(retail_df, weather_df, correlation_threshold=0.9):
    # 日付処理
    weather_df['日付'] = pd.to_datetime(weather_df['年月日.1'], errors='coerce')
    weather_df = weather_df.loc[:, ~weather_df.columns.str.contains(r'\.\d+$')]
    weather_df = weather_df.drop(columns=['最深積雪(cm)', '平均雲量(10分比)', '年月日'], errors='ignore')
    weather_df = weather_df.drop(index=[0, 1]).reset_index(drop=True)

    retail_df['日付'] = pd.to_datetime(retail_df['day'])
    retail_df = retail_df.drop(columns=['day'])

    merged = pd.merge(retail_df, weather_df, on='日付', how='left')

    # 広告統合とバイナリ化
    ad_cols = ['SNS', '売場施策', 'TV放映', 'プロモーション']
    for col in ad_cols:
        if col not in merged.columns:
            merged[col] = 0
    merged[ad_cols] = merged[ad_cols].fillna(0)
    for col in ad_cols:
        merged[col + '_有無'] = (merged[col] != 0).astype(int)
    merged['広告_有無'] = merged[[c + '_有無' for c in ad_cols]].max(axis=1)
    merged = merged.drop(columns = ad_cols + [col + '_有無' for col in ad_cols])

    # ラグ特徴量（商品ごと）
    for lag in [1, 2, 3]:
        merged[f'広告_有無_lag{lag}'] = merged.groupby('name')['広告_有無'].shift(lag).fillna(0).astype(int)

    # 移動平均（1つ前からの3点移動平均）
    merged['売上数_rollmean_prev3'] = (
        merged.groupby('name')['売上数']
              .apply(lambda s: s.shift(1).rolling(window=3, min_periods=1).mean())
              .reset_index(level=0, drop=True)
    ).fillna(0)

    # 特定の欠損処理（元スクリプトの意図を踏襲）
    merged = merged[merged.index != 3]  # 元コードで除外していた行
    beef_mask = (merged['name'] == '焙煎牛肉') & (merged.index >= 16) & (merged.index <= 94)
    for col in ['売上数', '売上高', '店頭在庫数', '納入予定数', '当店在庫手持週']:
        if col in merged.columns:
            mean_value = merged.loc[beef_mask, col].mean()
            merged.loc[beef_mask, col] = merged.loc[beef_mask, col].fillna(mean_value)

    # 客数の欠損埋め（元コードの値を参照）
    if '客数' in merged.columns:
        try:
            costomer_count_250928 = merged.loc[merged['日付'] == pd.to_datetime('2025-09-28'), '客数'].values[0]
            merged['客数'] = merged['客数'].fillna(costomer_count_250928)
        except Exception:
            merged['客数'] = merged['客数'].fillna(merged['客数'].mean())

    # 数値列の平均補完
    num_cols = ['price', '客数', '売上数', '売上高', '店頭在庫数', '納入予定数', '当店在庫手持週',
                '平均気温(℃)', '降水量の合計(mm)', '日照時間(時間)', '平均風速(m/s)', '平均蒸気圧(hPa)']
    num_cols = [c for c in num_cols if c in merged.columns]
    num_imputer = SimpleImputer(strategy='mean')
    merged[num_cols] = num_imputer.fit_transform(merged[num_cols])

    # IQRクリッピング（外れ値処理）
    for col in num_cols:
        Q1 = merged[col].quantile(0.25)
        Q3 = merged[col].quantile(0.75)
        IQR = Q3 - Q1
        lower = Q1 - 1.5 * IQR
        upper = Q3 + 1.5 * IQR
        merged[col] = merged[col].clip(lower, upper)

    # 時系列特徴量
    SEASON = {1: "WINTER",2: "WINTER",3: "SPRING",4: "SPRING",5: "SPRING",
              6: "SUMMER",7: "SUMMER",8: "SUMMER",9: "FALL",10: "FALL",11: "FALL",12: "WINTER"}
    merged['月'] = merged['日付'].dt.month
    merged['週'] = merged['日付'].dt.isocalendar().week
    merged['年'] = merged['日付'].dt.year
    merged['yday'] = merged['日付'].dt.dayofyear
    merged['season'] = merged['月'].map(SEASON)

    merged['yday_sin'] = np.sin(2 * np.pi * merged['yday'] / 365)
    merged['yday_cos'] = np.cos(2 * np.pi * merged['yday'] / 365)

    merged = merged.drop(columns=['月', '週', '年', 'yday'])

    # season のダミー化
    merged = pd.get_dummies(merged, columns=['season'], drop_first=True, dtype=int)


    ## 🚀 相互作用特徴量 (Interaction Features) の生成
    lag_ad = '広告_有無_lag3'
    # 1. 当店在庫手持週 と 広告有無_lag2 の相互作用項
    merged['Interaction_在庫手持週_広告'] = merged['当店在庫手持週'] * merged[lag_ad]
    # 2. 店頭在庫数 と 広告有無_lag2 の相互作用項
    merged['Interaction_店頭在庫数_広告'] = merged['店頭在庫数'] * merged[lag_ad]
    # 3. 納入予定数 と 広告有無_lag2 の相互作用項 (Optional: 相関が高かったため追加)
    merged['Interaction_納入予定数_広告'] = merged['納入予定数'] * merged[lag_ad]
    merged['Interaction_客数_広告'] = merged['客数'] * merged[lag_ad]
    merged['Interaction_price_広告'] = merged['price'] * merged[lag_ad]

    # 使いやすい順に列を整える（任意）
    merged = merged.reset_index(drop=True)

    # 高相関特徴量の自動削除
    print(f"\n--- 相関分析による特徴量フィルタリング (閾値: {correlation_threshold}) を開始 ---")

    # BERT特徴量以外の数値列のみを選択 (bert_vec_reducedは後で結合されるためここでは除外)
    # name, 日付, 売上高, 売上数 を除く、最終的な数値特徴量リスト
    final_num_cols = merged.select_dtypes(include=np.number).columns.tolist()

    # 目的変数やID的な列を除外
    cols_to_exclude = ['売上数', '売上高', '日付']
    feature_cols = [c for c in final_num_cols if c not in cols_to_exclude]

    corr_matrix = merged[feature_cols].corr().abs()

    # 上三角行列を取得 (重複を避けるため)
    upper = corr_matrix.where(np.triu(np.ones(corr_matrix.shape), k=1).astype(bool))

    # 閾値を超える特徴量を特定
    cols_to_drop_corr = set()
    for col in upper.columns:
        # 閾値を超える相関を持つ特徴量を見つける
        high_corr_features = upper.index[upper[col] > correlation_threshold]

        # 削除リストに追加 (ここでは、ペアのうち後にある列 'col' を優先的に削除)
        # より洗練された方法としては、平均PIが低い方を削除すべきですが、前処理ではシンプルに。
        for feature_to_drop in high_corr_features:
            # ペアのうち、すでに削除リストにない方の特徴量を選ぶ (列 'col' を残す)
            # NOTE: 'col' を残し、'feature_to_drop' を削除リストに入れる
            if feature_to_drop not in cols_to_drop_corr:
                cols_to_drop_corr.add(feature_to_drop)

    cols_to_drop_corr = list(cols_to_drop_corr)

    if cols_to_drop_corr:
        merged = merged.drop(columns=cols_to_drop_corr, errors='ignore')
        print(f" 高相関 ({correlation_threshold}以上) のため {len(cols_to_drop_corr)} 個の特徴量を削除しました:")
        print(cols_to_drop_corr)
    else:
        print(" 削除対象となる高相関な特徴量は見つかりませんでした。")

    print(f"最終的な特徴量候補数 (BERT特徴量を除く): {len(merged.columns) - 2} 個")  # name, 日付 を除く概算
    print(f"基本的な統計量\n{merged.describe()}")
    return merged


# --- 連続広告有無の特徴量作成 ---
def add_continuous_ad_features(df):
    """
    'name' ごとに '広告_有無' の連続回数と、そのラグ特徴量を作成する。
    """
    df_copy = df.copy()

    def calculate_consecutive_ad(series):
        # 1. 連続する値のブロックIDを作成
        # series.ne(series.shift()).cumsum() で、値が変わるたびにインデックスが増えるIDを作成
        # 例: [1, 1, 0, 1, 1, 1, 0, 0, 1] -> [1, 1, 2, 3, 3, 3, 4, 4, 5]
        block_id = series.ne(series.shift()).cumsum()

        # 2. block_idでグループ化し、各ブロック内で累積カウント (1から開始)
        consecutive_count = series.groupby(block_id).cumcount() + 1

        # 3. 広告がない期間 (値が0の期間) のカウントを0にする
        consecutive_count[series == 0] = 0

        return consecutive_count.astype(int)

    df_copy['広告_有無_連続'] = (
        df_copy.groupby('name')['広告_有無']
               .transform(calculate_consecutive_ad)
    )

    # 2. ラグ特徴量を作成
    for lag in [1, 2, 3]:
        df_copy[f'広告_有無_連続_lag{lag}'] = (
            df_copy.groupby('name')['広告_有無_連続'].shift(lag).fillna(0).astype(int)
        )

    return df_copy


def bert_features(text, layer=8):
    # テキスト → Tensor
    tokens = tokenizer(text, return_tensors='pt', truncation=True, max_length=128)

    with torch.no_grad():
        outputs = model(**tokens)

    hidden_states = outputs.hidden_states  # 全層 (13個)

    # ---- 使いたい層を選択 ----
    h = hidden_states[layer]  # shape: (1, seq_len, 768)

    # ---- CLSベクトルを特徴量にする ----
    cls_vec = h[:, 0, :].squeeze().numpy()  # shape: (768,)

    return cls_vec


def bert_features_batch(text_list, layer=8, batch_size=16):

    all_vecs = []

    for i in range(0, len(text_list), batch_size):
        batch_texts = text_list[i:i+batch_size]

        # まとめてトークナイズ（padding あり）
        tokens = tokenizer(batch_texts,
                           return_tensors='pt',
                           truncation=True,
                           padding=True,
                           max_length=128)

        with torch.no_grad():
            outputs = model(**tokens)

        hidden_states = outputs.hidden_states
        h = hidden_states[layer]       # shape: (B, seq_len, 768)
        mask = tokens["attention_mask"].unsqueeze(-1)

        # mean pooling
        h_masked = h * mask
        sum_vec = h_masked.sum(dim=1)
        len_tokens = mask.sum(dim=1)
        mean_vec = sum_vec / len_tokens  # shape: (B, 768)

        # numpy に変換
        all_vecs.append(mean_vec.numpy())

    # 全バッチを結合
    return np.vstack(all_vecs)


# --- BERT特徴量の次元削減（自己符号化器） ---
# 1. Autoencoderモデルの定義
class Autoencoder(nn.Module):
    def __init__(self, input_dim, latent_dim):
        super().__init__()

        # エンコーダー (768 -> 512 -> 128)
        self.encoder = nn.Sequential(
            nn.Linear(input_dim, 512),
            nn.ReLU(),
            nn.Linear(512, latent_dim)  # LATENT_DIM (低次元の特徴量)
        )

        # デコーダー (128 -> 512 -> 768)
        self.decoder = nn.Sequential(
            nn.Linear(latent_dim, 512),
            nn.ReLU(),
            nn.Linear(512, input_dim)  # 元の次元に戻す
        )

    def forward(self, x):
        encoded = self.encoder(x)
        decoded = self.decoder(encoded)
        return decoded

# 2. 学習と次元削減を行う関数
def reduce_bert_dimension(df, input_dim=768, latent_dim=128, epochs=50, lr=1e-3):
    print("\n--- Autoencoderによる次元削減を開始 ---")

    bert_data_np = np.vstack(df["bert_vec"].values)

    scaler = StandardScaler()
    bert_scaled_np = scaler.fit_transform(bert_data_np)

    X_tensor = torch.from_numpy(bert_scaled_np).float()

    model = Autoencoder(input_dim, latent_dim)
    optimizer = torch.optim.Adam(model.parameters(), lr=lr)
    criterion = nn.MSELoss()

    for epoch in range(epochs):
        model.train()

        # 順伝播
        outputs = model(X_tensor)
        loss = criterion(outputs, X_tensor)  # 入力データ X_tensor を再現できるか

        # 逆伝播と最適化
        optimizer.zero_grad()
        loss.backward()
        optimizer.step()

        if (epoch + 1) % 10 == 0:
            print(f'Epoch [{epoch + 1}/{epochs}], Loss: {loss.item():.6f}')

    model.eval()
    with torch.no_grad():
        # エンコーダー部分のみを使用して特徴量を抽出
        reduced_features_tensor = model.encoder(X_tensor)

    # Tensor -> NumPy
    reduced_features_np = reduced_features_tensor.numpy()

    df_reduced = df.copy()
    df_reduced['bert_vec_reduced'] = list(reduced_features_np)

    df_reduced = df_reduced.drop(columns=['bert_vec'])

    print(f"次元削減完了: {input_dim}次元 -> {latent_dim}次元")
    return df_reduced


# --- データの選択、分割、正規化 (目的変数スケーリング対応) ---
def prepare_data_for_ann(df, target_col='売上数'):
    # 目的変数の設定
    y = df[target_col].values.reshape(-1, 1)  # MinMaxScalerのため2次元に整形
    # y = np.log1p(y) # 対数変換

    # -----------------------------------------------------------
    # 1. 特徴量の選択と結合
    # -----------------------------------------------------------

    # 除外する列
    drop_cols = ['name', '日付', '売上高', target_col]

    # BERT特徴量を DataFrame の列に戻す
    bert_reduced_df = pd.DataFrame(df['bert_vec_reduced'].tolist(),
                                   index=df.index,
                                   columns=[f'bert_reduced_{i}' for i in
                                            range(df['bert_vec_reduced'].iloc[0].shape[0])])

    # 最終的な特徴量 DataFrame の作成
    X_base = df.drop(columns=drop_cols + ['bert_vec_reduced'], errors='ignore')
    X = pd.concat([X_base, bert_reduced_df], axis=1)

    feature_names = X.columns.tolist()

    # -----------------------------------------------------------
    # 2. 訓練:検証:テスト = 8:1:1 のデータ分割 (変更なし)
    # -----------------------------------------------------------

    train_ratio = 0.8
    val_test_ratio = 0.2
    val_ratio_in_val_test = 0.5

    n_samples = len(X)
    n_train = int(n_samples * train_ratio)
    n_val_test = n_samples - n_train
    n_val = int(n_val_test * val_ratio_in_val_test)

    train_idx = X.index[:n_train]
    val_idx = X.index[n_train:n_train + n_val]
    test_idx = X.index[n_train + n_val:n_samples]

    # データセットの分割
    X_train, y_train = X.loc[train_idx], y[train_idx]
    X_val, y_val = X.loc[val_idx], y[val_idx]
    X_test, y_test = X.loc[test_idx], y[test_idx]

    print(f"訓練データ数: {len(X_train)} ({len(X_train) / n_samples * 100:.1f}%)")

    # -----------------------------------------------------------
    # 3. 訓練データに基づく正規化（特徴量:StandardScaler, 目的変数:MinMaxScaler）
    # -----------------------------------------------------------

    # 特徴量 (X) の正規化: StandardScaler
    X_scaler = StandardScaler()
    X_scaler.fit(X_train)
    X_train_scaled = X_scaler.transform(X_train)
    X_val_scaled = X_scaler.transform(X_val)
    X_test_scaled = X_scaler.transform(X_test)

    # 目的変数 (y) の正規化: MinMaxScaler
    y_scaler = MinMaxScaler()
    y_scaler.fit(y_train)  # 訓練データのみで fit
    y_train_scaled = y_scaler.transform(y_train)
    y_val_scaled = y_scaler.transform(y_val)
    y_test_scaled = y_scaler.transform(y_test)

    print("特徴量および目的変数データのスケーリングが完了しました。")

    # -----------------------------------------------------------
    # 4. PyTorch Tensor への変換
    # -----------------------------------------------------------

    X_train_t, y_train_t = to_tensor_Xy(X_train_scaled, y_train_scaled.flatten())  # to_tensor_Xyで再度整形されるためflatten()
    X_val_t, y_val_t = to_tensor_Xy(X_val_scaled, y_val_scaled.flatten())
    X_test_t, y_test_t = to_tensor_Xy(X_test_scaled, y_test_scaled.flatten())

    print(f"ANNモデル入力次元: {X_train_t.shape[1]}")

    return {
        'X_train_t': X_train_t, 'y_train_t': y_train_t,
        'X_val_t': X_val_t, 'y_val_t': y_val_t,
        'X_test_t': X_test_t, 'y_test_t': y_test_t,
        'feature_names': feature_names,
        'y_scaler': y_scaler,
        'X_scaler': X_scaler,
        'train_idx': train_idx,
        'val_idx': val_idx,
        'test_idx': test_idx
    }


# --- ヘルパー: numpy -> torch tensor 変換 ---
def to_tensor_Xy(X_np, y_np):
    X_t = torch.from_numpy(X_np.astype(np.float32))
    y_t = torch.from_numpy(y_np.astype(np.float32)).reshape(-1, 1)
    return X_t, y_t


def prepare_data_for_ann_filtered(df, target_col='売上数', features_to_drop=[]):
    y = df[target_col].values.reshape(-1, 1)

    drop_cols_base = ['name', '日付', '売上高', target_col]

